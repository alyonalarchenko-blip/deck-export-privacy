  <defs>
    <symbol id="deck-export-icon" viewBox="0 0 128 128">
      <path d="M0 32C0 14.3269 14.3269 0 32 0H96C113.673 0 128 14.3269 128 32V96C128 113.673 113.673 128 96 128H32C14.3269 128 0 113.673 0 96V32Z" fill="url(#homeLogoGrad)"/>
      <path d="M34.2179 31.6193C34.2179 26.859 38.0769 23 42.8371 23H105.758C110.518 23 114.377 26.859 114.377 31.6193V77.9477C114.377 82.708 110.518 86.567 105.758 86.567H42.8371C38.0769 86.567 34.2179 82.708 34.2179 77.9477V31.6193Z" fill="#FEFEFE"/>
